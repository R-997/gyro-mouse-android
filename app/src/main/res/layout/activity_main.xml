<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.GyroMouse.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Gyro Mouse"
            app:titleTextColor="@color/white"
            app:popupTheme="@style/Theme.GyroMouse.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 状态卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:id="@+id/statusIndicator"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/circle_red"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="未连接"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/btnInit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="初始化 HID"
                            style="@style/Widget.MaterialComponents.Button" />

                        <Button
                            android:id="@+id/btnConnect"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:text="连接设备"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="移动: X=0, Y=0"
                        android:textSize="12sp"
                        android:textColor="@android:color/darker_gray"
                        android:gravity="center" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 控制设置卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="设置"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- 灵敏度 -->
                    <TextView
                        android:id="@+id/tvSensitivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="灵敏度: 3.5"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekSensitivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="33"
                        android:layout_marginBottom="16dp" />

                    <!-- 平滑度 -->
                    <TextView
                        android:id="@+id/tvSmoothing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="平滑度: 30%"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekSmoothing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="30"
                        android:layout_marginBottom="24dp" />

                    <!-- ===== 抖动优化设置 ===== -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:alpha="0.3"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="抖动优化"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- 死区 -->
                    <TextView
                        android:id="@+id/tvDeadZone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="死区: 0.05"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekDeadZone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="21"
                        android:layout_marginBottom="12dp" />

                    <!-- 速度衰减 -->
                    <TextView
                        android:id="@+id/tvVelocityDecay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="速度衰减: 85%"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekVelocityDecay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="71"
                        android:layout_marginBottom="12dp" />

                    <!-- 自适应平滑开关 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="自适应平滑"
                            android:textSize="13sp" />

                        <Switch
                            android:id="@+id/switchAdaptiveSmoothing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>

                    <!-- 传感器融合开关 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="传感器融合"
                            android:textSize="13sp" />

                        <Switch
                            android:id="@+id/switchSensorFusion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>

                    <!-- 融合系数 -->
                    <TextView
                        android:id="@+id/tvFusionAlpha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="融合系数: 2%"
                        android:textSize="12sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekFusionAlpha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="2"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:alpha="0.3"
                        android:layout_marginBottom="16dp" />

                    <!-- 滚轮控制开关 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Y轴滚轮控制"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switchWheel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>

                    <!-- 滚轮灵敏度 -->
                    <TextView
                        android:id="@+id/tvWheelSensitivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="滚轮灵敏度: 2.0"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekWheelSensitivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="33"
                        android:layout_marginBottom="12dp" />

                    <!-- 滚轮触发阈值 -->
                    <TextView
                        android:id="@+id/tvWheelThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="滚轮触发阈值: 0.3"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekWheelThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="22"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btnCalibrate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="校准传感器"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 鼠标按钮控制 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="鼠标按钮"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnLeft"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="左键"
                            android:textSize="16sp"
                            style="@style/Widget.MaterialComponents.Button" />

                        <Button
                            android:id="@+id/btnMiddle"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="中键"
                            android:textSize="16sp"
                            style="@style/Widget.MaterialComponents.Button" />

                        <Button
                            android:id="@+id/btnRight"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:text="右键"
                            android:textSize="16sp"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 说明区域 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="使用说明"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• 左右倾斜手机控制鼠标左右移动\n• 前后倾斜手机控制鼠标上下移动\n• 左右歪头控制滚轮滚动\n• 按住下方按钮进行点击\n• 调整灵敏度和死区获得最佳体验\n• 增大死区可减少微小抖动"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btnHelp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="查看详细帮助"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>